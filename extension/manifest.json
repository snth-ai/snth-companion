{
  "manifest_version": 3,
  "name": "SNTH Companion Browser Relay",
  "version": "0.1.0",
  "description": "Bridges Chrome to the SNTH Companion sidecar so your synth can operate your browser. Click the extension to attach/detach the active tab.",
  "permissions": ["debugger", "tabs", "activeTab", "storage"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "SNTH Companion Relay (click to attach/detach)"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
