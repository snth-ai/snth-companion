<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Hardened Runtime: required by Apple notarization (Nov 2019+).
       We keep the MINIMAL set. The three cs.* relaxations that used to be
       here (allow-unsigned-executable-memory, allow-dyld-environment-
       variables, disable-library-validation) were removed 2026-07-07:
       os/exec children (osascript/pbcopy/yt-dlp/ffmpeg) are NOT constrained
       by the parent's hardened runtime, and we neither JIT nor load
       third-party dylibs, so none of the three were actually needed and
       each only weakened the posture. WKWebView (control-panel window)
       runs its JS out-of-process in Apple's own WebContent service, so it
       needs no JIT entitlement here. VALIDATE on the first signed build:
       launch the app, open the control panel (webview) — if it fails to
       render, add back ONLY the specific entitlement it names. -->

  <!-- Apple events: required to drive Calendar/Notes/Reminders/etc.
       via osascript. The user still gets the TCC approval prompt on
       first use of each target app — this entitlement just declares
       we need the capability. -->
  <key>com.apple.security.automation.apple-events</key>
  <true/>

  <!-- Network client: WebSocket to the paired synth, HTTP to hub,
       OAuth to auth.openai.com. -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- No sandbox: we need to read/write files outside the app bundle
       (user-selected sandbox roots). Hardened runtime without app
       sandbox is a supported notarization configuration. -->
</dict>
</plist>
